<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.emailbuddy.companion</string>

    <key>ProgramArguments</key>
    <array>
      <string>__EMAILBUDDY_NODE__</string>
      <string>__EMAILBUDDY_ENTRYPOINT__</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
      <key>PATH</key>
      <string>__EMAILBUDDY_PATH__</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/emailbuddy.out.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/emailbuddy.err.log</string>
  </dict>
</plist>
